# tests/integration/Dockerfile.fedora
# Container Fedora para testes de integração do suap-setup
# Uso:
#   docker build -f tests/integration/Dockerfile.fedora -t suap-test-rpm .
#   docker run --rm suap-test-rpm bats tests/integration/test_dev_rpm.bats

FROM fedora:latest

ENV TERM=xterm-256color

# Instalar dependências básicas para execução dos testes
RUN dnf install -y \
    bash \
    git \
    python3 \
    python3-pip \
    curl \
    ca-certificates \
    sudo \
    glibc-langpack-pt \
    procps-ng \
    && dnf clean all

# Instalar bats-core
RUN dnf install -y bats && dnf clean all

# Copiar o projeto suap-setup para o container
COPY . /opt/suap-setup

WORKDIR /opt/suap-setup

# Garantir que os scripts de teste são executáveis
RUN chmod +x tests/run_tests.sh && \
    find tests/ -name "*.bats" -exec chmod +r {} \; && \
    find . -name "*.sh" -exec chmod +x {} \;

# Configurar o ambiente para os testes
ENV PROJECT_ROOT=/opt/suap-setup

# Comando padrão: executar todos os testes de integração RPM
CMD ["bash", "-c", "tests/test_helper/bats-core/bin/bats tests/integration/test_dev_rpm.bats tests/integration/test_prod_rpm.bats"]
